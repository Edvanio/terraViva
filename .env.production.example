# ──────────────────────────────────────────────────────────────────
# Ambiente: DEVELOP (deploy no DO App Platform)
# Por ora não há ambiente de produção separado.
# Copie este arquivo para .env.production e preencha os valores.
# NUNCA commite o .env.production no git.
# ──────────────────────────────────────────────────────────────────

# MongoDB Atlas
MONGODB_URL=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>
MONGODB_DB_NAME=terra_viva

# JWT — gere uma chave forte: openssl rand -hex 32
SECRET_KEY=troque-esta-chave-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — domínio do App Platform
CORS_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1,http://127.0.0.1:3000,https://terra-viva-vnvaf.ondigitalocean.app

# OTP padrão — 123456 liberado (ambiente develop)
DEV_OTP_DEFAULT=123456

# DigitalOcean Spaces (armazenamento de uploads)
DO_SPACES_KEY=<sua-spaces-key>
DO_SPACES_SECRET=<seu-spaces-secret>
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=us-east-1
DO_SPACES_BUCKET=<seu-bucket>
DO_SPACES_FOLDER=terraviva/profiles

# Next.js — URL interna do backend (mesmo container via nginx)
API_INTERNAL_URL=http://127.0.0.1:8000

# URL pública da API (usada pelo frontend no browser)
NEXT_PUBLIC_API_URL=https://terra-viva-vnvaf.ondigitalocean.app/api
