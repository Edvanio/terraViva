# ──────────────────────────────────────────────────────────────────
# Ambiente de desenvolvimento local
# Copie para .env.develop e preencha os valores.
# ──────────────────────────────────────────────────────────────────

# MongoDB Atlas (recomendado usar banco separado: terra_viva_dev)
MONGODB_URL=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>
MONGODB_DB_NAME=terra_viva_dev

# JWT
SECRET_KEY=dev-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1,http://127.0.0.1:3000

# OTP padrão liberado em dev
DEV_OTP_DEFAULT=123456

# DigitalOcean Spaces
DO_SPACES_KEY=<sua-spaces-key>
DO_SPACES_SECRET=<seu-spaces-secret>
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=us-east-1
DO_SPACES_BUCKET=<seu-bucket>
DO_SPACES_FOLDER=terraviva/profiles

# Next.js (docker compose — comunicação interna pela rede docker)
NEXT_PUBLIC_API_URL=http://localhost/api
API_INTERNAL_URL=http://backend:8000
